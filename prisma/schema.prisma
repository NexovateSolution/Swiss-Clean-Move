generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Client {
  id                  String    @id @default(cuid())
  firstName           String
  lastName            String
  email               String?
  phone               String
  address             String
  postalCode          String
  location            String
  squareMeters        Int
  serviceType         String
  buildingType        String
  fromDate            DateTime
  untilDate           DateTime
  totalPrice          Float
  paidAmount          Float     @default(0)
  balance             Float
  status              String    @default("UNPAID")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  elevator            String?
  floor               String?
  numberOfRooms       String?
  prefix              String?
  remarks1            String?
  remarks2            String?
  remarks3            String?
  deploymentFrequency String?
  data                Json?
  invoices            Invoice[]
  payments            Payment[]
  photos              Photo[]
}

model Payment {
  id          String   @id @default(cuid())
  clientId    String
  amount      Float
  paymentDate DateTime @default(now())
  method      String   @default("CASH")
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Photo {
  id           String   @id @default(cuid())
  clientId     String
  filename     String
  originalName String
  url          String
  size         Int
  mimeType     String
  createdAt    DateTime @default(now())
  client       Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Invoice {
  id            String    @id @default(cuid())
  clientId      String
  invoiceNumber String    @unique
  amount        Float
  status        String    @default("PENDING")
  dueDate       DateTime
  paidDate      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model QuoteSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  service   String
  details   String
  status    String   @default("NEW")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  status    String   @default("NEW")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ServiceFormSubmission {
  id                  String   @id @default(cuid())
  serviceName         String
  formType            String
  firstName           String
  name                String
  emailAddress        String
  telephone           String
  streetAndNumber     String
  postalCodeAndCity   String
  submissionDate      DateTime @default(now())
  pdfPath             String?
  contactPreferredVia String?
  viewingIsWelcome    String?
  remark              String?
  data                Json
  status              String   @default("NEW")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}
